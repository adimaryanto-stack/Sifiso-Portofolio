{
  "name": "sifiso-monorepo",
  "version": "0.0.0",
  "packageManager": "npm@10.8.2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@vercel/style-guide": "^6.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "^2.9.6",
    "eslint-plugin-only-warn": "^1.2.1",
    "turbo": "latest"
  }
}
